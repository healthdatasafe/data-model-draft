{
  "version": "1.0.0",
  "types": {
    "vulva-mucus-inspect/v0": {
      "description": "Cervical Fluid Inspect",
      "type": "string",
      "enum": [
        "clear",
        "creamy",
        "dry-sticky",
        "egg-white"
      ]
    },
    "contact/country": {
      "description": "Country",
      "type": "string"
    },
    "contact/name": {
      "description": "Name",
      "type": "string"
    },
    "contact/surname": {
      "description": "Surname",
      "type": "string"
    },
    "reproductive-sexuality/detailed": {
      "description": "Potentially reproductive sexual activity",
      "type": "string",
      "enum": [
        "fertile",
        "incomplete",
        "withdrawal",
        "condom",
        "cervical-barrier",
        "protected"
      ]
    },
    "ratio/proportion": {
      "description": "A proportion value from 0 to 1. Represents a fraction of a whole: 0 = none, 1 = maximum. Used for subjective scales (e.g. bleeding intensity) where reference points are defined by item options.",
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "test-result/scale": {
      "description": "Generic qualitative test result on a scale from -1 to 1. Negative values indicate a negative result, 0 indicates indeterminate, positive values indicate a positive result. The magnitude represents intensity or confidence. Common values: -1 (negative), 0 (indeterminate), 1 (positive). Intermediate values can represent semi-quantitative results (e.g., 0.5 for a weak positive). Applicable to any binary or semi-quantitative test: medical (OPK, pregnancy, COVID), environmental, industrial, etc.",
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "pregnancy/detailed": {
      "description": "Pregnancy. The value of `event.time` should indicate the start of pregnancy. When content value is 'ongoing' `event.duration` must be set to `null`. For any other value `event.duration` should be set to indicate when the pregnancy state terminated.",
      "type": "string",
      "enum": [
        "ongoing",
        "miscarriage",
        "ectopic",
        "stillbirth",
        "livebirth",
        "abortion"
      ]
    },
    "medication/basic": {
      "description": "Simple medication intake identified by free-text name. 'intake' follows the same structure as medication/coded-v1 for dose and route.",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "description": "Free-text name of the medication",
          "type": "string"
        },
        "intake": {
          "description": "User-entered intake regimen",
          "type": "object",
          "properties": {
            "doseValue": {
              "description": "Amount per intake (e.g. 2 for '2 tablets', 5 for '5 mL')",
              "type": "number"
            },
            "doseUnit": {
              "description": "HDS eventType reference for the dose unit",
              "type": "string",
              "enum": [
                "dose/tablet",
                "dose/drop",
                "dose/puff",
                "dose/application",
                "dose/suppository",
                "dose/unit",
                "volume/ml",
                "mass/mg",
                "mass/mcg",
                "mass/g"
              ]
            },
            "route": {
              "description": "Route of administration",
              "type": "string",
              "enum": [
                "oral",
                "sublingual",
                "parenteral",
                "intravenous",
                "intramuscular",
                "subcutaneous",
                "inhalation",
                "nasal",
                "topical",
                "transdermal",
                "ophthalmic",
                "otic",
                "rectal",
                "vaginal"
              ]
            }
          }
        }
      }
    },
    "medication/coded-v1": {
      "description": "Coded medication intake. 'drug' is the coded identity from datasets-service, 'intake' is the user-entered regimen. Maps to FHIR MedicationStatement: drug → medicationCodeableConcept, intake → dosage.",
      "type": "object",
      "required": ["drug"],
      "properties": {
        "drug": {
          "description": "Coded drug identity, populated from datasets-service selection. Contains multiple codes when the same drug is matched across coding systems.",
          "type": "object",
          "required": ["label", "codes"],
          "properties": {
            "label": {
              "description": "Localized medication name for display",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "description": {
              "description": "Localized full description (e.g. 'Aspirin 325 MG Oral Tablet')",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "codes": {
              "description": "Coding identifiers across systems. A single drug may have codes in RxNorm (prescribing), SNOMED-CT (clinical), and ATC (classification).",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code", "system", "hdsId"],
                "properties": {
                  "code": {
                    "description": "Code value (rxcui, SCTID, ATC code)",
                    "type": "string"
                  },
                  "system": {
                    "description": "Coding system: RxNorm, SNOMED-CT, ATC",
                    "type": "string"
                  },
                  "source": {
                    "description": "Data source reference",
                    "type": "object",
                    "properties": {
                      "key": { "type": "string" }
                    }
                  },
                  "hdsId": {
                    "description": "Unique HDS identifier for this code entry",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "intake": {
          "description": "User-entered intake regimen",
          "type": "object",
          "properties": {
            "doseValue": {
              "description": "Amount per intake (e.g. 2 for '2 tablets', 5 for '5 mL')",
              "type": "number"
            },
            "doseUnit": {
              "description": "HDS eventType reference for the dose unit",
              "type": "string",
              "enum": [
                "dose/tablet",
                "dose/drop",
                "dose/puff",
                "dose/application",
                "dose/suppository",
                "dose/unit",
                "volume/ml",
                "mass/mg",
                "mass/mcg",
                "mass/g"
              ]
            },
            "route": {
              "description": "Route of administration",
              "type": "string",
              "enum": [
                "oral",
                "sublingual",
                "parenteral",
                "intravenous",
                "intramuscular",
                "subcutaneous",
                "inhalation",
                "nasal",
                "topical",
                "transdermal",
                "ophthalmic",
                "otic",
                "rectal",
                "vaginal"
              ]
            }
          }
        }
      }
    },
    "medication/prescription-v1": {
      "description": "Medication prescription. Captures what the doctor prescribed: drug identity, dosage, frequency, and instructions. event.duration reflects the full treatment period.",
      "type": "object",
      "required": ["drug"],
      "properties": {
        "drug": {
          "description": "Coded drug identity, populated from datasets-service selection.",
          "type": "object",
          "required": ["label", "codes"],
          "properties": {
            "label": {
              "description": "Localized medication name for display",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "description": {
              "description": "Localized full description (e.g. 'Aspirin 325 MG Oral Tablet')",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "codes": {
              "description": "Coding identifiers across systems.",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code", "system", "hdsId"],
                "properties": {
                  "code": { "type": "string" },
                  "system": { "type": "string" },
                  "source": {
                    "type": "object",
                    "properties": {
                      "key": { "type": "string" }
                    }
                  },
                  "hdsId": { "type": "string" }
                }
              }
            }
          }
        },
        "posology": {
          "description": "Prescribed dosage and schedule",
          "type": "object",
          "properties": {
            "doseValue": {
              "description": "Amount per intake (e.g. 2 for '2 tablets')",
              "type": "number"
            },
            "doseUnit": {
              "description": "HDS eventType reference for the dose unit",
              "type": "string",
              "enum": [
                "dose/tablet",
                "dose/drop",
                "dose/puff",
                "dose/application",
                "dose/suppository",
                "dose/unit",
                "volume/ml",
                "mass/mg",
                "mass/mcg",
                "mass/g"
              ]
            },
            "route": {
              "description": "Route of administration",
              "type": "string",
              "enum": [
                "oral",
                "sublingual",
                "parenteral",
                "intravenous",
                "intramuscular",
                "subcutaneous",
                "inhalation",
                "nasal",
                "topical",
                "transdermal",
                "ophthalmic",
                "otic",
                "rectal",
                "vaginal"
              ]
            },
            "frequency": {
              "description": "Prescribed frequency (e.g. 2 times per day)",
              "$ref": "#/types/frequency~1times-period"
            },
            "asNeeded": {
              "description": "True if taken as needed (PRN) rather than on schedule",
              "type": "boolean"
            },
            "note": {
              "description": "Free text instructions (e.g. 'take with food', 'before bedtime')",
              "type": "string"
            }
          }
        }
      }
    },
    "mass/mcg": {
      "description": "Micrograms",
      "type": "number"
    },
    "dose/tablet": {
      "description": "Tablets or capsules count",
      "type": "number"
    },
    "dose/drop": {
      "description": "Drops (ophthalmic, otic, nasal, oral)",
      "type": "number"
    },
    "dose/puff": {
      "description": "Puffs or actuations (inhalers, nasal sprays)",
      "type": "number"
    },
    "dose/application": {
      "description": "Applications (topical creams, ointments, gels, patches)",
      "type": "number"
    },
    "dose/suppository": {
      "description": "Suppositories (rectal, vaginal)",
      "type": "number"
    },
    "dose/unit": {
      "description": "International Units (IU)",
      "type": "number"
    },
    "concentration/mg-ml": {
      "description": "Milligrams per milliliter",
      "type": "number"
    },
    "concentration/mcg-ml": {
      "description": "Micrograms per milliliter",
      "type": "number"
    },
    "concentration/mg-g": {
      "description": "Milligrams per gram (topical)",
      "type": "number"
    },
    "rate/mg-hr": {
      "description": "Milligrams per hour (transdermal, infusion)",
      "type": "number"
    },
    "rate/mcg-hr": {
      "description": "Micrograms per hour (transdermal)",
      "type": "number"
    },
    "frequency/times-period": {
      "description": "Number of times per period. E.g. 2 times per day, 1 time per week.",
      "type": "object",
      "required": ["times", "period", "periodUnit"],
      "properties": {
        "times": {
          "description": "Number of intakes per period (e.g. 2 for 'twice a day')",
          "type": "number",
          "minimum": 1
        },
        "period": {
          "description": "Length of the period (e.g. 1 for 'per day', 8 for 'every 8 hours')",
          "type": "number",
          "minimum": 1
        },
        "periodUnit": {
          "description": "Unit of the period",
          "type": "string",
          "enum": ["h", "d", "wk", "mo", "y"]
        }
      }
    },
    "settings/preferred-locales": {
      "description": "User preferred locales, ordered by priority",
      "type": "array",
      "items": { "type": "string" }
    },
    "settings/theme": {
      "description": "UI theme preference",
      "type": "string",
      "enum": ["light", "dark"]
    },
    "settings/timezone": {
      "description": "User timezone (IANA identifier)",
      "type": "string"
    },
    "settings/date-format": {
      "description": "Preferred date display format",
      "type": "string",
      "enum": ["DD.MM.YYYY", "DD/MM/YYYY", "MM/DD/YYYY", "YYYY-MM-DD"]
    },
    "settings/unit-system": {
      "description": "Preferred measurement unit system",
      "type": "string",
      "enum": ["metric", "imperial"]
    },
    "contact/display-name": {
      "description": "User display name",
      "type": "string"
    },
    "cervix-position/3d-vectors": {
      "description": "Cervical position observation as three 0–1 vectors: height (low→high), firmness (firm→soft), openness (closed→open). Each dimension follows the fertility direction (0 = least fertile, 1 = most fertile).",
      "type": "object",
      "properties": {
        "height": {
          "description": "Cervix height: 0 = low, 0.5 = medium, 1 = high",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "firmness": {
          "description": "Cervix firmness: 0 = firm, 0.5 = medium, 1 = soft",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "openness": {
          "description": "Cervical os openness: 0 = closed, 0.5 = medium, 1 = open",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "mood/5d-vectors": {
      "description": "Mood observation as five 0–1 dimensional vectors based on Russell's Circumplex and PAD models. Valence (unpleasant→pleasant), arousal (calm→activated), dominance (powerless→in-control), social orientation (self→other-focused), temporal focus (past→future).",
      "type": "object",
      "properties": {
        "valence": {
          "description": "Pleasure/displeasure: 0 = very unpleasant, 0.5 = neutral, 1 = very pleasant",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "arousal": {
          "description": "Energy/activation: 0 = very calm, 0.5 = moderate, 1 = very activated",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "dominance": {
          "description": "Sense of control: 0 = powerless, 0.5 = neutral, 1 = in control",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "socialOrientation": {
          "description": "Social focus: 0 = self-focused, 0.5 = balanced, 1 = other-focused",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "temporalFocus": {
          "description": "Time orientation: 0 = past-dwelling, 0.5 = present, 1 = future-anticipating",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  },
  "extras": {
