  "fertility-ttc-tta": {
    "version": "v1",
    "label": {
      "en": "Trying to conceive / Avoiding pregnancy"
    },
    "description": {
      "en": "Current fertility intention"
    },
    "streamId": "fertility-ttc-tta",
    "eventType": "ratio/generic",
    "type": "select",
    "options": [
      {
        "value": 0,
        "label": {
          "en": "TTA - Not taking risks.  Would take all available measures to end a pregnancy."
        }
      },
      {
        "value": 1,
        "label": {
          "en": "TTA - Not taking risks.  Would strongly consider placing baby for adoption."
        }
      },
      {
        "value": 2,
        "label": {
          "en": "TTA - Not taking risks.  Would need some time, maybe counseling. Ultimately keeping the pregnancy."
        }
      },
      {
        "value": 4,
        "label": {
          "en": "TTA - Not taking risks.  Currently content with family size but a surprise pregnancy would be welcome."
        }
      },
      {
        "value": 5,
        "label": {
          "en": "TTW/TTA - \"Loosely TTA\" known risks are taken in the fertile window. \"OOPS\" pregnancy would be welcome."
        }
      },
      {
        "value": 6,
        "label": {
          "en": "TTW - Charting only for health/curiosity. Unprotected intercourse happens whenever. Pregnancy very welcome."
        }
      },
      {
        "value": 7,
        "label": {
          "en": "TTW/TTC - Pregnancy very welcome (moving up the scale in very near future)."
        }
      },
      {
        "value": 8,
        "label": {
          "en": "TTC - \"Excited to start/grow a family TTC\" Intentional intercourse every cycle. Excited to start/grow a family. But would not use any fertility treatments if needed."
        }
      },
      {
        "value": 9,
        "label": {
          "en": "TTC - \"Highly hopeful TTC\" Intentional intercourse every cycle. Would consider some but not all fertility treatments if needed."
        }
      },
      {
        "value": 10,
        "label": {
          "en": "TTC - \" Seriously TTC\" Intentional intercourse every cycle. Would pursue any/ALL fertility treatments or procedures if needed."
        }
      }
    ],
    "repeatable": "P1D"
  },
